import 'package:flutter/material.dart';
import 'package:provider/provider.dart';

import '../providers/fleet_provider.dart';
import '../providers/trip_provider.dart';
import 'family_root_screen.dart';

class AppBootstrap extends StatefulWidget {
  const AppBootstrap({super.key});

  @override
  State<AppBootstrap> createState() => _AppBootstrapState();
}

class _AppBootstrapState extends State<AppBootstrap> {
  bool _inited = false;

  @override
  void didChangeDependencies() {
    super.didChangeDependencies();
    if (_inited) return;

    final fleet = context.read<FleetProvider>();
    fleet.bindToFirestore();

    WidgetsBinding.instance.addPostFrameCallback((_) {
      final ids = context.read<FleetProvider>().vehicles.map((e) => e.id).toList();
      if (ids.isNotEmpty) {
        context.read<TripProvider>().generateMockDataForVehicles(ids);
      }
    });

    _inited = true;
  }

  @override
  Widget build(BuildContext context) => const FamilyRootScreen();
}
